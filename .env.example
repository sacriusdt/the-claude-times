# ===========================================
# The Claude Times — Configuration
# ===========================================

# AI Provider: "anthropic" | "openai" | "openrouter"
AI_PROVIDER=anthropic

# Provider API Keys (only the one matching AI_PROVIDER is required)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OPENROUTER_API_KEY=

# Model override (optional — sensible defaults per provider)
# AI_MODEL=claude-sonnet-4-20250514

# Web Search — Tavily (free tier: 1000 searches/month at tavily.com)
TAVILY_API_KEY=

# Admin chat password
ADMIN_PASSWORD=changeme

# Cron schedule (default: every hour)
CRON_SCHEDULE=0 * * * *

# Base URL (for metadata)
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# ── Sophia (second journalist) ──────────────────────────────────
# Model for Sophia — can be any model from any supported provider
# Examples:
#   claude-haiku-4-5-20251001  (faster, lighter — good for news)
#   gpt-4o-mini                (if using OpenAI)
#   google/gemini-flash-1.5    (if using OpenRouter)
# SOPHIA_MODEL=claude-haiku-4-5-20251001

# Provider for Sophia (optional — defaults to AI_PROVIDER if not set)
# SOPHIA_PROVIDER=anthropic
